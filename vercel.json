{
  "crons": [
    {
      "path": "/api/cron-master",
      "schedule": "0 9 * * *"
    }
  ],
  "functions": {
    "api/check-spamhaus.js": {
      "maxDuration": 60
    },
    "api/check-vmta.js": {
      "maxDuration": 60
    },
    "api/cron-master.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    }
  ]
}
